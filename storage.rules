rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if the user is the owner of the request
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Helper function to check if the user has an admin role
    function isAdmin() {
      // Assumes user roles are stored in Firestore at /users/{userId}
      return request.auth != null && 
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // 1. REQUESTS DOCUMENTS
    // New Path Structure: `requests/{userId}/{requestId}/{filename}`
    // This allows cryptographic validation of ownership without DB reads for the path check.
    match /requests/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Strict Write:
      // 1. Must be owner of the path segment (userId)
      // 2. Metadata must also declare ownership (Double Check)
      // 3. Size limit 10MB
      allow write: if isOwner(userId)
                   && request.resource.metadata.ownerId == userId
                   && request.resource.size < 10 * 1024 * 1024;
                   
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    // LEGACY SUPPORT (Optional - Remove if no active users)
    // Deprecated: `requests/{requestId}/{filename}`
    // match /requests/{requestId}/{allPaths=**} { ... } 
    // (Removed per user confirmation of no active users)

    // 2. HCM EMPLOYEE DOCUMENTS
    // Path: `employees/{employeeId}/{...}`
    
    // Permitir lectura pública de avatar (para organigrama y otros)
    match /employees/{employeeId}/avatar {
      allow read: if request.auth != null;
      allow write: if isAdmin() ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['HRManager', 'Admin'];
    }

    // Only HR Manager or Admin can access.
    match /employees/{employeeId}/{allPaths=**} {
      allow read, write: if isAdmin() ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['HRManager', 'Admin'];
    }
    
    // 3. PUBLIC ASSETS
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
