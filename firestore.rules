/**
 * # Firestore Security Rules: FlowMaster Prototyping
 *
 * ## Core Philosophy
 * This ruleset enforces a strict user-ownership security model. All user-generated
 * data (like Requests, Workflow Steps, and Documents) is stored in subcollections
 * under that user's private document tree. Access is fundamentally controlled by
 * the path of the document, ensuring users can only interact with their own data.
 * Publicly accessible data, like request templates, is structurally segregated
 * into its own top-level collection with read-only permissions for all users.
 *
 * ## Data Structure
 * - `/request_templates/{requestTemplateId}`: A public, read-only collection of available workflow templates.
 * - `/users/{userId}`: A collection of user profiles. Each user can only access and manage their own document.
 * - `/users/{userId}/requests/{requestId}`: A private subcollection where each user stores their submitted requests.
 * - `/tasks/{taskId}`: A centralized collection for all actionable tasks. Access is controlled by the `assigneeId` field.
 * - `/users/{userId}/requests/{requestId}/...`: Deeper subcollections for documents, inheriting ownership from the parent request.
 *
 * ## Key Security Decisions
 * - **Strict Ownership**: All data under `/users/{userId}` is accessible only to the authenticated user whose UID matches `{userId}`.
 * - **No User Enumeration (for non-admins)**: Listing documents in the top-level `/users` collection is disallowed for regular users to protect privacy. Admins are an exception.
 * - **Public Read-Only Templates**: Request templates are readable by anyone (including unauthenticated users) to allow for a flexible UI, but are not writable by clients to protect their integrity.
 * - **Task-Based Access**: Users can read tasks assigned to them from the `/tasks` collection. They can update tasks if they are the assignee.
 *
 * ## Denormalization for Authorization
 * To ensure fast and secure authorization, rules rely on denormalized fields. For example, a new document in `/users/{userId}/requests/{requestId}` must contain a `submittedBy` field that matches `{userId}`.
 *
 * ## Structural Segregation
 * The separation of public data (`/request_templates`) from private user data (`/users`) is a deliberate choice. The introduction of the `/tasks` collection is another example, allowing for efficient, secure queries on assigned tasks without exposing unrelated data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    /**
     * Verifies that a user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Verifies that the currently signed-in user's UID matches the
     * provided `userId`. This is the primary ownership check.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || isAdmin();
    }

    /**
     * Verifies ownership for an existing document. Used for update/delete
     * operations to prevent acting on non-existent data.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Checks if the requesting user has the 'Admin' role.
     * This requires a get() call to the user's own profile document.
     */
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }


    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Defines rules for request templates, which are public and read-only for all clients.
     * @path /request_templates/{requestTemplateId}
     */
    match /request_templates/{requestTemplateId} {
      allow get, list: if true;
      allow write: if isSignedIn();
    }

    /**
     * @description Manages user profiles. A user can read/update their own profile. Admins can read all profiles and update any profile.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwnerOrAdmin(userId);
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwnerOrAdmin(userId);
      allow delete: if isAdmin(); // Only admins can delete users
    }

     /**
     * @description Manages user-submitted requests. Only the owner can perform any action on their requests.
     * @path /users/{userId}/requests/{requestId}
     */
    match /users/{userId}/requests/{requestId} {
      allow get, list, create, update, delete: if isOwner(userId);

      /**
       * @description Manages documents attached to a specific request. Access is inherited from the parent request's owner.
       * @path /users/{userId}/requests/{requestId}/documents/{documentId}
       */
      match /documents/{documentId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.requestId == requestId;
        allow update: if isExistingOwner(userId) && request.resource.data.requestId == resource.data.requestId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Manages the central tasks collection.
     * @path /tasks/{taskId}
     */
    match /tasks/{taskId} {
      // Allow reading a single task if you are the assignee.
      allow get: if isSignedIn() && request.auth.uid == resource.data.assigneeId;
      // Allow any signed-in user to list all tasks for analytics purposes on the dashboard.
      allow list: if isSignedIn();
      // Allow creating a task if you are the owner of the parent request.
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.requestOwnerId;
      // Allow updating a task if you are the assignee.
      allow update: if isSignedIn() && request.auth.uid == resource.data.assigneeId;
      // Disallow client-side deletes for now to maintain history.
      allow delete: if false;
    }
  }
}
