
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }
    
    // NEW: Check role from the custom token claim. Much more efficient.
    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || hasRole('Admin');
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Defines rules for request templates, which are public and read-only for all clients.
     * @path /request_templates/{requestTemplateId}
     */
    match /request_templates/{requestTemplateId} {
      allow get, list: if isSignedIn();
      // Allow create, update, delete only for Admins or Designers
      allow write: if hasRole('Admin') || hasRole('Designer');
    }

    /**
     * @description Manages user profiles. A user can read/update their own profile. Admins can manage all profiles.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwnerOrAdmin(userId);
      allow list: if hasRole('Admin'); // Only Admins can list all users
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwnerOrAdmin(userId); // Users can update their own profile, Admins can update any
      allow delete: if hasRole('Admin'); // Only admins can delete users

      /**
       * @description Manages user notifications. Only the owner can read, update, or delete their notifications.
       * @path /users/{userId}/notifications/{notificationId}
       */
      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) || hasRole('Admin'); // System (via admin) can create notifications
        allow update, delete: if isOwner(userId);
      }
    }

     /**
     * @description Manages user-submitted requests. Only the owner can perform any action on their requests. Admins can view all requests.
     * @path /users/{userId}/requests/{requestId}
     */
    match /users/{userId}/requests/{requestId} {
      allow list: if hasRole('Admin');
      allow get, create, update, delete: if isOwner(userId);

      match /documents/{documentId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      match /comments/{commentId} {
        allow get, list, create, update, delete: if isOwner(userId) || hasRole('Admin');
      }

      match /audit_logs/{auditLogId} {
        allow get, list: if isOwnerOrAdmin(userId);
        allow create: if isOwnerOrAdmin(userId);
        allow update, delete: if false; // Immutable
      }
    }
    
    /**
     * @description Allows collection group queries on requests for admin users.
     * @path /{path=**}/requests/{requestId}
     */
    match /{path=**}/requests/{requestId} {
      // Admins can read all requests across all users for reporting/search
      allow read: if hasRole('Admin');
    }

    /**
     * @description Manages the central tasks collection.
     * @path /tasks/{taskId}
     */
    match /tasks/{taskId} {
      // Allow reading a single task if you are the assignee, owner of the request, or an admin.
      allow get: if isSignedIn() && (request.auth.uid == resource.data.assigneeId || request.auth.uid == resource.data.requestOwnerId || hasRole('Admin'));
      
      // Allow any signed-in user to list all tasks for analytics, but specific filtering should be done client-side or with more specific rules.
      allow list: if isSignedIn();
      
      // Allow creating a task if you are the owner of the parent request.
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.requestOwnerId;
      
      // Allow updating a task if you are the assignee or an Admin.
      // A manager could also update, which requires a more complex rule.
      allow update: if isSignedIn() && (request.auth.uid == resource.data.assigneeId || hasRole('Admin'));
      
      // Disallow client-side deletes for now to maintain history. Admins are an exception.
      allow delete: if hasRole('Admin');
    }
  }
}
