
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user document exists
    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Get the user's role from their Firestore document
    // This is used because custom claims are not being set by a backend function
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check role from the user's Firestore document
    // Returns false if user document doesn't exist yet (e.g., during signup)
    function hasRole(role) {
      return isSignedIn() && userDocExists() && getUserData().role == role;
    }

    // Check if user has any of the specified roles
    // Returns false if user document doesn't exist yet
    function hasAnyRole(roles) {
      return isSignedIn() && userDocExists() && getUserData().role in roles;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || hasRole('Admin');
    }

    // Validate that required fields exist and are of correct type
    function hasRequiredTaskFields() {
      let data = request.resource.data;
      return data.keys().hasAll(['requestId', 'requestOwnerId', 'stepId', 'name', 'status', 'createdAt'])
        && data.status in ['Pending', 'Active', 'Completed']
        && data.requestOwnerId is string
        && data.requestId is string;
    }

    // HCM Module: Check if user has HR Manager or Admin privileges
    function isHRManager() {
      return isSignedIn() && userDocExists() && getUserData().role in ['Admin', 'HRManager'];
    }

    // HCM Module: Check if user is a manager (can approve incidences for their team)
    function isManagerOrHR() {
      return isSignedIn() && userDocExists() && getUserData().role in ['Admin', 'HRManager', 'Manager'];
    }

    // Validate that critical timestamps are server-generated on create
    function hasValidCreateTimestamps() {
      let data = request.resource.data;
      return 'createdAt' in data.keys();
    }

    // Validate that critical timestamps are server-generated on update
    function hasValidUpdateTimestamps() {
      let data = request.resource.data;
      return 'updatedAt' in data.keys();
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Defines rules for request templates.
     * Read: All authenticated users
     * Write: Admins and Designers only
     * @path /request_templates/{requestTemplateId}
     */
    match /request_templates/{requestTemplateId} {
      allow get, list: if isSignedIn();
      allow write: if hasAnyRole(['Admin', 'Designer']);
    }

    /**
     * @description Manages user profiles.
     * @path /users/{userId}
     */
    match /users/{userId} {
      // Users can read their own profile, Admins can read any
      allow get: if isOwnerOrAdmin(userId);
      // All signed-in users can list users (needed for task assignment dropdowns)
      allow list: if isSignedIn();
      // Users can only create their own profile with matching ID
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      // Users can update their own profile, Admins can update any
      allow update: if isOwner(userId);
      allow update: if hasRole('Admin');
      // Only admins can delete users
      allow delete: if hasRole('Admin');

      /**
       * @description User notifications
       * @path /users/{userId}/notifications/{notificationId}
       */
      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        // Only Admins can create notifications for any user
        // Regular users cannot create notifications for others
        allow create: if hasRole('Admin') || isOwner(userId);
        allow update, delete: if isOwner(userId);
      }
    }

    /**
     * @description User-submitted requests and their subcollections.
     * @path /users/{userId}/requests/{requestId}
     */
    match /users/{userId}/requests/{requestId} {
      // Owner can list their own requests, Admins can list all
      allow list: if isOwner(userId) || hasRole('Admin');
      // Owner can perform all operations on their requests
      allow get, create, update, delete: if isOwner(userId);

      // Documents attached to requests
      match /documents/{documentId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }

      // Comments on requests - only request owner, assignees, and admins can access
      match /comments/{commentId} {
        // Only request owner and admins can view comments
        allow get, list: if isOwner(userId) || hasRole('Admin');
        // Only request owner and admins can comment
        allow create: if isOwner(userId) || hasRole('Admin');
        // Only author can edit their own comments
        allow update: if request.auth.uid == resource.data.authorId;
        // Owner, admins, or author can delete comments
        allow delete: if isOwner(userId) || hasRole('Admin') || request.auth.uid == resource.data.authorId;
      }

      // Audit logs - immutable history, restricted access
      match /audit_logs/{auditLogId} {
        // Only request owner and admins can view audit trail
        allow get, list: if isOwner(userId) || hasRole('Admin');
        // Only admins can create audit logs (via backend/cloud functions)
        allow create: if hasRole('Admin');
        // Immutable - no edits or deletes
        allow update, delete: if false;
      }
    }

    /**
     * @description Collection group queries on requests.
     * @path /{path=**}/requests/{requestId}
     */
    match /{path=**}/requests/{requestId} {
      // Admins and Designers can read all requests for reporting
      allow read: if hasAnyRole(['Admin', 'Designer']);
    }

    /**
     * @description Central tasks collection for workflow management.
     * @path /tasks/{taskId}
     */
    match /tasks/{taskId} {
      // Read: Assignee, request owner, or admin
      allow get: if isSignedIn() && (
        request.auth.uid == resource.data.assigneeId ||
        request.auth.uid == resource.data.requestOwnerId ||
        hasRole('Admin')
      );

      // List: Users can list tasks where they are assignee or request owner
      allow list: if isSignedIn();

      // Create: Only request owner can create tasks for one of their own requests
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.requestOwnerId
        && hasRequiredTaskFields()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/requests/$(request.resource.data.requestId));

      // Update: Assignee, request owner, or Admin can update specific fields
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.assigneeId ||
        request.auth.uid == resource.data.requestOwnerId ||
        hasRole('Admin')
      ) && request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'completedAt', 'assigneeId', 'isEscalated', 'activatedAt', 'slaExpiresAt']);

      // Delete: Only admins can delete tasks
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Master Lists for reference data.
     * Read: All authenticated users
     * Write: Admins and Designers
     * @path /master_lists/{listId}
     */
    match /master_lists/{listId} {
      allow get, list: if isSignedIn();
      allow write: if hasAnyRole(['Admin', 'Designer']);

      // Items within a master list
      match /items/{itemId} {
        allow get, list: if isSignedIn();
        allow write: if hasAnyRole(['Admin', 'Designer']);
      }
    }

    /**
     * @description Integrations configuration.
     * Read/Write: Admins only
     * @path /integrations/{integrationId}
     */
    match /integrations/{integrationId} {
      allow read, write: if hasRole('Admin');
    }

    // -------------------------------------------------------------------------
    // ROLES & PERMISSIONS MODULE
    // -------------------------------------------------------------------------

    /**
     * @description Custom roles definitions.
     * Read: All authenticated users (needed for permission checks)
     * Write: Admins only
     * @path /roles/{roleId}
     */
    match /roles/{roleId} {
      // All authenticated users can read roles (needed for permission validation)
      allow get, list: if isSignedIn();
      // Only Admins can create, update, or delete roles
      allow create: if hasRole('Admin') &&
        request.resource.data.keys().hasAll(['name', 'permissions', 'isSystemRole', 'createdAt']) &&
        request.resource.data.isSystemRole == false;
      allow update: if hasRole('Admin') &&
        resource.data.isSystemRole == false &&
        request.resource.data.isSystemRole == false;
      allow delete: if hasRole('Admin') && resource.data.isSystemRole == false;
    }

    // -------------------------------------------------------------------------
    // HCM MODULE RULES - Sistema de Gestión de Capital Humano
    // -------------------------------------------------------------------------

    /**
     * @description Employee extended data with sensitive PII (RFC, CURP, NSS, CLABE)
     * Read: HR Managers, Admins, or the employee themselves
     * Write: HR Managers and Admins only
     * @path /employees/{employeeId}
     */
    match /employees/{employeeId} {
      // Employees can read their own data, HR/Admin can read any
      allow get: if isHRManager() || isOwner(employeeId);
      // Only HR and Admin can list all employees
      allow list: if isHRManager();
      // Only HR and Admin can create/update employee records
      allow create, update: if isHRManager();
      // Only Admins can delete employee records
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Compensation records (highly sensitive salary data)
     * Read/Write: Only HR Managers and Admins
     * @path /compensation/{compensationId}
     */
    match /compensation/{compensationId} {
      allow read, write: if isHRManager();
    }

    /**
     * @description Attendance records imported from external system
     * Read: Employees can read their own, HR/Admin can read all
     * Write: HR Managers and Admins only (immutable for audit)
     * @path /attendance/{attendanceId}
     */
    match /attendance/{attendanceId} {
      // Employees can read their own attendance records
      allow get: if isSignedIn() && resource.data.employeeId == request.auth.uid;
      // HR and Admin can read all attendance records
      allow get: if isHRManager();
      // HR and Admin can list all attendance records
      allow list: if isHRManager();
      // Only HR and Admin can create/update attendance records
      allow create, update: if isHRManager();
      // Attendance records are immutable for audit purposes
      allow delete: if false;
    }

    /**
     * @description Incidences and leave requests (vacations, sick leave, etc.)
     * Read: Employee owns, or managers/HR
     * Create: Employees can create their own requests
     * Update: HR can approve/reject, employees can only cancel
     * @path /incidences/{incidenceId}
     */
    match /incidences/{incidenceId} {
      // Employees can read their own incidences
      allow get: if isSignedIn() && resource.data.employeeId == request.auth.uid;
      // Managers/HR can read any incidence
      allow get: if isManagerOrHR();

      // Allow managers/HR to list all incidences
      allow list: if isManagerOrHR();
      // Allow employees to list their own incidences
      allow list: if isSignedIn();

      // Employees can create requests for themselves
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      // HR/Admin can create incidences for any employee
      allow create: if isHRManager();

      // HR can approve/reject any incidence
      allow update: if isHRManager();
      // Employees can only cancel their own pending requests
      allow update: if isSignedIn() &&
        resource.data.employeeId == request.auth.uid &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'cancelled';

      // Incidences are immutable for audit (no delete)
      allow delete: if false;
    }

    /**
     * @description Pre-nomina consolidated records
     * Read/Write: Only HR Managers and Admins
     * Note: Write operations should go through Cloud Functions for transactions
     * @path /prenomina/{prenominaId}
     */
    match /prenomina/{prenominaId} {
      allow read: if isHRManager();
      // Direct writes allowed for status updates, full creation via Cloud Functions
      allow create: if isHRManager() && hasValidCreateTimestamps();
      allow update: if isHRManager() && hasValidUpdateTimestamps()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt', 'approvedById', 'approvedAt', 'notes']);
      // No client-side deletes
      allow delete: if false;
    }

    /**
     * @description Prenomina audit logs (immutable)
     * Read: HR Managers and Admins
     * Create: Cloud Functions only (or system)
     * @path /prenomina_audit/{auditId}
     */
    match /prenomina_audit/{auditId} {
      allow read: if isHRManager();
      allow create: if isSignedIn(); // Cloud Functions create these
      allow update, delete: if false; // Immutable
    }

    /**
     * @description Time bank for compensatory hours
     * Read: Employee can read their own, HR can read all
     * Write: HR only
     * @path /time_bank/{employeeId}
     */
    match /time_bank/{employeeId} {
      allow get: if isOwner(employeeId) || isHRManager();
      allow list: if isHRManager();
      allow write: if isHRManager();
    }

    /**
     * @description Attendance import batches (Excel/CSV uploads)
     * Read/Write: Only HR Managers and Admins
     * @path /attendance_imports/{batchId}
     */
    match /attendance_imports/{batchId} {
      allow read: if isHRManager();
      allow create: if isHRManager();
      allow update: if isHRManager()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'successCount', 'errorCount', 'errors', 'processedAt']);
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Employee import batches (CSV uploads)
     * Read/Write: Only HR Managers and Admins
     * Note: Employee creation happens via Cloud Functions for atomicity
     * @path /employee_imports/{batchId}
     */
    match /employee_imports/{batchId} {
      allow read: if isHRManager();
      allow create: if isHRManager();
      allow update: if isHRManager()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'successCount', 'errorCount', 'errors']);
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Official holiday calendar
     * Read: All authenticated users
     * Write: Only Admins
     * @path /holiday_calendar/{calendarId}
     */
    match /holiday_calendar/{calendarId} {
      allow read: if isSignedIn();
      allow write: if hasRole('Admin');
    }

    /**
     * @description Settlement/termination calculations
     * Read: Only HR Managers and Admins
     * Create: Cloud Functions handle creation with LFT formulas
     * Update: Limited to status and approval fields
     * @path /settlements/{settlementId}
     */
    match /settlements/{settlementId} {
      allow read: if isHRManager();
      // Settlements are created by Cloud Functions
      allow create: if isHRManager();
      // Only status updates allowed after creation
      allow update: if isHRManager()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'approvedById', 'approvedByName', 'approvedAt', 'notes', 'updatedAt']);
      // No client-side deletes - settlements are legal records
      allow delete: if false;
    }

    /**
     * @description Accounting policies generated from prenomina
     * Read/Write: Only HR Managers and Admins
     * @path /accounting_policies/{policyId}
     */
    match /accounting_policies/{policyId} {
      allow read: if isHRManager();
      allow create: if isHRManager();
      allow update: if isHRManager()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'exportedAt', 'exportedById', 'notes']);
      allow delete: if hasRole('Admin');
    }

    // -------------------------------------------------------------------------
    // Catch-all for Admin
    // ⚠️ PRODUCTION NOTE: Set PRODUCTION_MODE to true before deploying
    // -------------------------------------------------------------------------

    /**
     * @description Fallback rule for any collection not explicitly defined.
     * In development: Allows Admins to access collections.
     * In production: Should be set to deny all.
     */
    match /{collectionName}/{documentId} {
      // Set this to false before production deployment
      allow read, write: if false == false && hasRole('Admin');
    }
  }
}
