
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user document exists
    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Get the user's role from their Firestore document
    // This is used because custom claims are not being set by a backend function
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check role from the user's Firestore document
    // Returns false if user document doesn't exist yet (e.g., during signup)
    function hasRole(role) {
      return isSignedIn() && userDocExists() && getUserData().role == role;
    }

    // Check if user has any of the specified roles
    // Returns false if user document doesn't exist yet
    function hasAnyRole(roles) {
      return isSignedIn() && userDocExists() && getUserData().role in roles;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || hasRole('Admin');
    }

    // Check if user's role grants access to the requests module
    // Simplified role-based check (Firestore rules cannot iterate permission arrays)
    function canAccessRequests() {
      return isSignedIn() && userDocExists()
        && getUserData().role in ['Admin', 'Designer', 'HRManager', 'Manager'];
    }

    // Validate that required fields exist and are of correct type
    function hasRequiredTaskFields() {
      let data = request.resource.data;
      return data.keys().hasAll(['requestId', 'requestOwnerId', 'stepId', 'name', 'status', 'createdAt'])
        && data.status in ['Pending', 'Active', 'Completed']
        && data.requestOwnerId is string
        && data.requestId is string;
    }

    // HCM Module: Check if user has HR Manager or Admin privileges
    function isHRManager() {
      return isSignedIn() && userDocExists() && getUserData().role in ['Admin', 'HRManager'];
    }

    // HCM Module: Check if user is a manager (can approve incidences for their team)
    function isManagerOrHR() {
      return isSignedIn() && userDocExists() && getUserData().role in ['Admin', 'HRManager', 'Manager'];
    }

    // Validate that critical timestamps are server-generated on create
    function hasValidCreateTimestamps() {
      let data = request.resource.data;
      return 'createdAt' in data.keys();
    }

    function hasValidUpdateTimestamps() {
      let data = request.resource.data;
      return 'updatedAt' in data.keys();
    }

    // Function to identify protected collections where Admin cannot write via wildcard
    function isProtectedCollection(path) {
      return path[0] == 'audit_logs' ||
             path[0] == 'prenomina_audit' ||
             path[0] == 'compensation' ||
             path[0] == 'vacation_balances';
    }

    // ============================================
    // NIVEL 4: PROTECCIÓN GLOBAL (Forbidden Zones)
    // ============================================
    // Bloquear acceso a colecciones prohibidas explícitamente, incluso para admins
    match /secrets/{document=**} { allow read, write: if false; }
    match /system_keys/{document=**} { allow read, write: if false; }

    // ============================================
    // NIVEL 3: SOLO LECTURA PARA ADMIN (Root Level)
    // ============================================
    match /audit_logs/{logId} {
      allow read: if hasRole('Admin');
      allow create: if hasRole('Admin'); // Admin puede crear (via backend/console)
      allow update, delete: if false; // INMUTABLE
    }

    // -------------------------------------------------------------------------
    // Collection Rules
    // -------------------------------------------------------------------------

    /**
     * @description Defines rules for request templates.
     * Read: All authenticated users
     * Write: Admins and Designers only
     * @path /request_templates/{requestTemplateId}
     */
    match /request_templates/{requestTemplateId} {
      allow get, list: if isSignedIn();
      allow write: if hasAnyRole(['Admin', 'Designer']);
    }

    /**
     * @description Manages user profiles.
     * @path /users/{userId}
     */
    match /users/{userId} {
      // Users can read their own profile, Admins can read any
      allow get: if isOwnerOrAdmin(userId);
      // All signed-in users can list users (needed for task assignment dropdowns)
      allow list: if isSignedIn();
      // Users can only create their own profile with matching ID
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      // Users can update their own profile, Admins can update any
      allow update: if isOwner(userId);
      allow update: if hasRole('Admin');
      // Only admins can delete users
      allow delete: if hasRole('Admin');

      /**
       * @description User notifications
       * @path /users/{userId}/notifications/{notificationId}
       */
      match /notifications/{notificationId} {
        allow get, list: if isOwner(userId);
        // Any authenticated user can create notifications (needed for incidence routing)
        allow create: if isSignedIn();
        allow update, delete: if isOwner(userId);
      }
    }

    /**
     * @description User-submitted requests and their subcollections.
     * @path /users/{userId}/requests/{requestId}
     */
    match /users/{userId}/requests/{requestId} {
      // Helper function to check if user is assigned to a task for this request
      function isAssignee() {
        return isSignedIn() && exists(/databases/$(database)/documents/tasks/$(requestId)) 
          || true; // TODO: properly query tasks, but cross-collection queries in rules without doc ID are tricky. 
          // An alternative is an array in the request doc for 'assignees', or allowing read if they have 'requests' module permission.
      }
      
      // Allow read if user is owner, admin, or has requests module access
      allow get, list: if isOwner(userId) || hasRole('Admin') || canAccessRequests();

      // Owner can create/update/delete
      allow create, update, delete: if isOwner(userId);

      // Documents attached to requests
      match /documents/{documentId} {
        allow get, list: if isOwner(userId) || hasRole('Admin') || canAccessRequests();
        allow create, update, delete: if isOwner(userId);
      }

      // Comments on requests
      match /comments/{commentId} {
        // Owner, admins, and assignees (users with requests access) can view comments
        allow get, list: if isOwner(userId) || hasRole('Admin') || canAccessRequests();
        // Owner, admins, and assignees can comment
        allow create: if isOwner(userId) || hasRole('Admin') || canAccessRequests();
        // Only author can edit their own comments
        allow update: if request.auth.uid == resource.data.authorId;
        // Owner, admins, or author can delete comments
        allow delete: if isOwner(userId) || hasRole('Admin') || request.auth.uid == resource.data.authorId;
      }

      // Audit logs - immutable history, restricted access
      match /audit_logs/{auditLogId} {
        // Only request owner and admins can view audit trail
        allow get, list: if isOwner(userId) || hasRole('Admin');
        // Only admins can create audit logs (via backend/cloud functions)
        allow create: if hasRole('Admin');
        // Immutable - no edits or deletes
        allow update, delete: if false;
      }
    }

    /**
     * @description Collection group queries on requests.
     * @path /{path=**}/requests/{requestId}
     */
    match /{path=**}/requests/{requestId} {
      // Admins, Designers, HRManagers, and Managers can read requests via collection group queries
      // Managers need this for viewing requests they are assigned to approve
      allow read: if hasAnyRole(['Admin', 'Designer', 'HRManager', 'Manager']);
    }

    /**
     * @description Central tasks collection for workflow management.
     * @path /tasks/{taskId}
     */
    match /tasks/{taskId} {
      // Read: Assignee, request owner, or admin
      allow get: if isSignedIn() && (
        request.auth.uid == resource.data.assigneeId ||
        request.auth.uid == resource.data.requestOwnerId ||
        hasRole('Admin')
      );

      // List: Users can list tasks where they are assignee or request owner
      allow list: if isSignedIn();

      // Create: Only request owner can create tasks for one of their own requests
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.requestOwnerId
        && hasRequiredTaskFields()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/requests/$(request.resource.data.requestId));

      // Create: Allow incidence-related tasks (no BPMN request existence check needed)
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.requestOwnerId
        && request.resource.data.type in ['incidence_approval', 'justification', 'tardiness_review', 'departure_review', 'overtime_review'];

      // Update: Assignee, request owner, or Admin can update specific fields
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.assigneeId ||
        request.auth.uid == resource.data.requestOwnerId ||
        hasRole('Admin')
      ) && request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['status', 'completedAt', 'assigneeId', 'isEscalated', 'activatedAt', 'slaExpiresAt']);

      // Delete: Only admins can delete tasks
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Master Lists for reference data.
     * Read: All authenticated users
     * Write: Admins and Designers
     * @path /master_lists/{listId}
     */
    match /master_lists/{listId} {
      allow get, list: if isSignedIn();
      allow write: if hasAnyRole(['Admin', 'Designer']);

      // Items within a master list
      match /items/{itemId} {
        allow get, list: if isSignedIn();
        allow write: if hasAnyRole(['Admin', 'Designer']);
      }
    }

    /**
     * @description Integrations configuration.
     * Read/Write: Admins only
     * @path /integrations/{integrationId}
     */
    match /integrations/{integrationId} {
      allow read, write: if hasRole('Admin');
    }

    // -------------------------------------------------------------------------
    // ROLES & PERMISSIONS MODULE
    // -------------------------------------------------------------------------

    /**
     * @description Custom roles definitions.
     * Read: All authenticated users (needed for permission checks)
     * Write: Admins only
     * @path /roles/{roleId}
     */
    match /roles/{roleId} {
      // All authenticated users can read roles (needed for permission validation)
      allow get, list: if isSignedIn();
      // Only Admins can create, update, or delete roles
      allow create: if hasRole('Admin') &&
        request.resource.data.keys().hasAll(['name', 'permissions', 'isSystemRole', 'createdAt']) &&
        request.resource.data.isSystemRole == false;
      allow update: if hasRole('Admin') &&
        resource.data.isSystemRole == false &&
        request.resource.data.isSystemRole == false;
      allow delete: if hasRole('Admin') && resource.data.isSystemRole == false;
    }

    // -------------------------------------------------------------------------
    // HCM MODULE RULES - Sistema de Gestión de Capital Humano
    // -------------------------------------------------------------------------

    /**
     * @description Employee extended data with sensitive PII (RFC, CURP, NSS, CLABE)
     * Read: HR Managers, Admins, or the employee themselves
     * Write: HR Managers and Admins only
     * @path /employees/{employeeId}
     */
    match /employees/{employeeId} {
      // All authenticated users can read employees (needed for org chart hierarchy)
      // Sensitive salary data is in the separate 'compensation' collection
      allow read: if isSignedIn();
      // Only HR and Admin can create/update employee records
      allow create, update: if isHRManager();
      // Admin solo puede borrar si ya está inactivo (Soft delete enforce)
      allow delete: if hasRole('Admin') && resource.data.status == 'inactive';
    }

    /**
     * @description Compensation records (highly sensitive salary data)
     * Read/Write: Only HR Managers and Admins
     * @path /compensation/{compensationId}
     */
    match /compensation/{compensationId} {
      allow read, create, update: if isHRManager();
      allow delete: if false; // Nunca borrar historial salarial
    }

    /**
     * @description Attendance records imported from external system
     * Read: Employees can read their own, HR/Admin can read all
     * Write: HR Managers and Admins only (immutable for audit)
     * @path /attendance/{attendanceId}
     */
    match /attendance/{attendanceId} {
      // Employees can read their own attendance records
      allow get: if isSignedIn() && resource.data.employeeId == request.auth.uid;
      // HR and Admin can read all attendance records
      allow get: if isHRManager();
      // HR and Admin can list all attendance records
      allow list: if isHRManager();
      // Only HR and Admin can create/update attendance records
      allow create, update: if isHRManager();
      // Attendance records are immutable for audit purposes
      allow delete: if false;
    }

    /**
     * @description Incidences and leave requests (vacations, sick leave, etc.)
     * Read: Employee owns, or managers/HR
     * Create: Employees can create their own requests
     * Update: HR can approve/reject, employees can only cancel
     * @path /incidences/{incidenceId}
     */
    match /incidences/{incidenceId} {
      // Employees can read their own incidences
      allow get: if isSignedIn() && resource.data.employeeId == request.auth.uid;
      // Managers/HR can read any incidence
      allow get: if isManagerOrHR();

      // Allow managers/HR to list all incidences
      allow list: if isManagerOrHR();
      // Allow employees to list their own incidences
      allow list: if isSignedIn();

      // Employees can create requests for themselves
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      // HR/Admin/Manager can create incidences for any employee
      allow create: if isManagerOrHR();

      // HR and Managers can approve/reject incidences
      allow update: if isManagerOrHR();
      // Employees can only cancel their own pending requests
      allow update: if isSignedIn() &&
        resource.data.employeeId == request.auth.uid &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'cancelled';

      // Incidences are immutable for audit (no delete)
      allow delete: if false;
    }

    /**
     * @description Pre-nomina consolidated records
     * Read/Write: Only HR Managers and Admins
     * Note: Write operations should go through Cloud Functions for transactions
     * @path /prenomina/{prenominaId}
     */
    match /prenomina/{prenominaId} {
      allow read: if isHRManager();
      // Direct writes allowed for status updates, full creation via Cloud Functions
      allow create: if isHRManager() && hasValidCreateTimestamps();
      allow update: if isHRManager() && hasValidUpdateTimestamps()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt', 'approvedById', 'approvedAt', 'notes']);
      // No client-side deletes
      allow delete: if false;
    }

    /**
     * @description Prenomina audit logs (immutable)
     * Read: HR Managers and Admins
     * Create: Cloud Functions only (or system)
     * @path /prenomina_audit/{auditId}
     */
    match /prenomina_audit/{auditId} {
      allow read: if isHRManager();
      allow create: if isSignedIn(); // Cloud Functions create these
      allow update, delete: if false; // Immutable
    }

    // NOTE: time_bank rules are defined below (after early_departures/missing_punches)
    // to avoid duplication. The previous block here was removed because its
    // `allow write` (which includes delete) conflicted with the intended
    // `allow delete: if false` in the detailed block below.

    /**
     * @description Attendance import batches (Excel/CSV uploads)
     * Read/Write: Only HR Managers and Admins
     * @path /attendance_imports/{batchId}
     */
    match /attendance_imports/{batchId} {
      allow read: if isManagerOrHR();
      allow create: if isHRManager();
      allow update: if isHRManager()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'successCount', 'errorCount', 'errors', 'processedAt', 'dateRangeStart', 'dateRangeEnd']);
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Employee import batches (CSV uploads)
     * Read/Write: Only HR Managers and Admins
     * Note: Employee creation happens via Cloud Functions for atomicity
     * @path /employee_imports/{batchId}
     */
    match /employee_imports/{batchId} {
      allow read: if isHRManager();
      allow create: if isHRManager();
      allow update: if isHRManager()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'successCount', 'errorCount', 'errors']);
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Official holiday calendar
     * Read: All authenticated users
     * Write: Only Admins
     * @path /holiday_calendar/{calendarId}
     */
    match /holiday_calendar/{calendarId} {
      allow read: if isSignedIn();
      allow write: if hasRole('Admin');
    }

    /**
     * @description Accounting policies generated from prenomina
     * Read/Write: Only HR Managers and Admins
     * @path /accounting_policies/{policyId}
     */
    match /accounting_policies/{policyId} {
      allow read: if isHRManager();
      allow create: if isHRManager();
      allow update: if isHRManager()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'exportedAt', 'exportedById', 'notes']);
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Departments - Organizational units with hierarchy
     * Read: All authenticated users (needed for dropdowns, org chart)
     * Write: Only HR Managers and Admins
     * @path /departments/{departmentId}
     */
    match /departments/{departmentId} {
      // All users can read departments (needed for UI dropdowns, org chart)
      allow get, list: if isSignedIn();
      // Only HR and Admin can create departments
      allow create: if isHRManager() && hasValidCreateTimestamps();
      // Only HR and Admin can update departments
      allow update: if isHRManager() && hasValidUpdateTimestamps();
      // Only Admins can delete departments (soft delete preferred)
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Vacation balances for employees
     * Read: Employee can read their own, HR can read all
     * Write: HR only (balance updates happen through incidence approval)
     * @path /vacation_balances/{balanceId}
     */
    match /vacation_balances/{balanceId} {
      // Employees can read their own vacation balance (get + list for queries)
      allow get, list: if isSignedIn();
      // HR can read any vacation balance
      allow get, list: if isHRManager();
      // Only HR can modify vacation balances (balance updates via incidence approval)
      allow create, update: if isHRManager();
      // No deletes - balance history is important
      allow delete: if false;
    }

    /**
     * @description Vacation adjustment audit trail
     * Read: HR only
     * Write: HR only (created during balance adjustments)
     * @path /vacation_adjustments/{adjustmentId}
     */
    match /vacation_adjustments/{adjustmentId} {
      allow read: if isHRManager();
      allow create: if isHRManager();
      // No updates or deletes - audit trail is immutable
      allow update, delete: if false;
    }

    /**
     * @description Tardiness records for tracking late arrivals
     * Read: Employee can read their own, HR/Manager can read all
     * Write: HR only
     * @path /tardiness_records/{recordId}
     */
    match /tardiness_records/{recordId} {
      // Employees can read their own tardiness records
      allow get: if isSignedIn() && resource.data.employeeId == request.auth.uid;
      // Managers and HR can read any tardiness record
      allow get, list: if isManagerOrHR();
      // Only HR can create/update tardiness records
      allow create, update: if isHRManager();
      // Managers can justify tardiness (limited update)
      allow update: if hasAnyRole(['Manager']) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['isJustified', 'justificationReason', 'justifiedById', 'justifiedAt', 'updatedAt']);
      // No deletes
      allow delete: if false;
    }

    /**
     * @description Overtime requests and approvals
     * Read: Employee can read their own, Manager/HR can read all
     * Create: Employees can create their own requests
     * Update: Managers/HR can approve/reject
     * @path /overtime_requests/{requestId}
     */
    match /overtime_requests/{requestId} {
      // Employees can read their own overtime requests
      allow get: if isSignedIn() && resource.data.employeeId == request.auth.uid;
      // Managers and HR can read any overtime request
      allow get, list: if isManagerOrHR();
      // Employees can create overtime requests for themselves
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      // Managers and HR can approve/reject overtime requests
      allow update: if isManagerOrHR();
      // No deletes
      allow delete: if false;
    }

    /**
     * @description Payroll period locks to prevent modifications after export
     * Read: HR Managers and Admins
     * Write: HR Managers and Admins (unlock requires Admin)
     * @path /payroll_period_locks/{lockId}
     */
    match /payroll_period_locks/{lockId} {
      allow read: if isManagerOrHR();
      allow create: if isHRManager();
      // Unlocking requires Admin
      allow update: if hasRole('Admin');
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Manager review status for period closures
     * Read: Managers, HR Managers, and Admins
     * Write: Managers (mark review complete), HR Managers and Admins
     * @path /manager_review_status/{reviewId}
     */
    match /manager_review_status/{reviewId} {
      allow read: if isManagerOrHR();
      allow create, update: if isManagerOrHR();
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Positions catalog
     * Read: All authenticated users
     * Write: HR Managers and Admins
     * @path /positions/{positionId}
     */
    match /positions/{positionId} {
      allow get, list: if isSignedIn();
      allow create, update: if isHRManager();
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Locations/branches catalog
     * Read: All authenticated users
     * Write: HR Managers and Admins
     * @path /locations/{locationId}
     */
    match /locations/{locationId} {
      allow get, list: if isSignedIn();
      allow create, update: if isHRManager();
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Shifts catalog (turnos)
     * Read: All authenticated users
     * Write: HR Managers and Admins
     * @path /shifts/{shiftId}
     */
    match /shifts/{shiftId} {
      allow get, list: if isSignedIn();
      allow create, update: if isHRManager();
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Custom shifts catalog (DEPRECATED - use /shifts instead)
     * Read: All authenticated users
     * Write: HR Managers and Admins
     * @path /custom_shifts/{shiftId}
     */
    match /custom_shifts/{shiftId} {
      allow get, list: if isSignedIn();
      allow create, update: if isHRManager();
      allow delete: if hasRole('Admin');
    }

    /**
     * @description Holiday calendars by year/location
     * Read: All authenticated users
     * Write: Admins only
     * @path /holiday_calendars/{calendarId}
     */
    match /holiday_calendars/{calendarId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if hasRole('Admin');
    }

    /**
     * @description Tardiness policy configuration
     * Read: All authenticated users
     * Write: Admins only
     * @path /tardiness_policy/{policyId}
     */
    match /tardiness_policy/{policyId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if hasRole('Admin');
    }

    /**
     * @description Early departure records (salidas tempranas)
     * Read: Employee can read their own, Manager/HR can read all
     * Create: HR/Admin and system (via Cloud Functions)
     * Update: Managers can justify (limited fields), HR can update all
     * @path /early_departures/{recordId}
     */
    match /early_departures/{recordId} {
      // Employees can read their own early departure records
      allow get: if isSignedIn() && resource.data.employeeId == request.auth.uid;
      // Managers and HR can read any early departure record
      allow get, list: if isManagerOrHR();
      // HR can create early departure records
      allow create: if isHRManager();
      // Managers can justify early departures (limited fields)
      allow update: if hasAnyRole(['Manager']) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['isJustified', 'justificationReason', 'justifiedById', 'justifiedByName', 'justifiedAt', 'resultedInAbsence', 'updatedAt']);
      // HR can update all fields
      allow update: if isHRManager();
      // No deletes - history is important
      allow delete: if false;
    }

    /**
     * @description Missing punch records (marcajes faltantes)
     * Read: Employee can read their own, Manager/HR can read all
     * Create: HR/Admin and system (via Cloud Functions)
     * Update: Managers can justify (provide times), HR can update all
     * @path /missing_punches/{recordId}
     */
    match /missing_punches/{recordId} {
      // Employees can read their own missing punch records
      allow get: if isSignedIn() && resource.data.employeeId == request.auth.uid;
      // Managers and HR can read any missing punch record
      allow get, list: if isManagerOrHR();
      // HR can create missing punch records
      allow create: if isHRManager();
      // Managers can justify missing punches (provide times and justification)
      allow update: if hasAnyRole(['Manager']) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['isJustified', 'justificationReason', 'providedEntryTime', 'providedExitTime',
                    'generatedTardinessId', 'generatedEarlyDepartureId', 'justifiedById',
                    'justifiedByName', 'justifiedAt', 'resultedInAbsence', 'updatedAt']);
      // HR can update all fields
      allow update: if isHRManager();
      // No deletes - history is important
      allow delete: if false;
    }

    /**
     * @description Time bank records (bolsa de horas)
     * Read: Employee (own), Manager (team), HR/Admin (all)
     * Write: HR/Admin only (balance updates happen through Cloud Functions)
     * @path /time_bank/{employeeId}
     */
    match /time_bank/{employeeId} {
      // Employees can read their own time bank
      allow get: if isSignedIn() && employeeId == request.auth.uid;
      // Managers and HR can read any time bank (Managers need it for team view)
      allow get, list: if isManagerOrHR();
      // Only HR/Admin can modify time banks
      allow create, update: if isHRManager();
      // No deletes
      allow delete: if false;
    }

    /**
     * @description Shift assignments for employees
     * Read: Manager (team), HR/Admin (all)
     * Write: Manager (assign), HR/Admin (full)
     * @path /shift_assignments/{assignmentId}
     */
    match /shift_assignments/{assignmentId} {
      allow get, list: if isManagerOrHR();
      allow create, update: if isManagerOrHR();
      allow delete: if isHRManager();
    }

    // -------------------------------------------------------------------------
    // Catch-all for Admin (Recursive God Mode)
    // ⚠️ ZERO TRUST ENFORCED: Default is DENY ALL.
    // -------------------------------------------------------------------------

    /**
     * @description Recursive match for ALL documents in the database.
     * Allows Admins to read/write ANY document.
     * Prerequisite: All critical Admin actions MUST be logged to 'audit_logs' via backend.
     */
    match /{document=**} {
      // 1. Permitir lectura global para debug/soporte
      allow read: if hasRole('Admin');
      
      // 2. Escritura permitida SOLO si NO es una colección protegida
      allow write: if hasRole('Admin') && !isProtectedCollection(document);
    }

  }
}
